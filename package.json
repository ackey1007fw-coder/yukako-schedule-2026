{
  "name": "yukako-fan-schedule-2026",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "images:build": "node scripts/generate-responsive-images.mjs",
    "images:og:baby-shark": "node scripts/generate-baby-shark-og-image.mjs",
    "images:og:akita-to-tokyo": "node scripts/generate-akita-to-tokyo-og-image.mjs",
    "add:news": "node scripts/add-news.mjs",
    "test:add-news": "node scripts/test-add-news.mjs",
    "test:baby-shark-updates": "node scripts/test-baby-shark-updates.mjs",
    "test:gojet": "node scripts/test-gojet-status.mjs",
    "prebuild": "node scripts/generate-responsive-images.mjs && node scripts/generate-sitemap.mjs",
    "typecheck": "tsc -b",
    "build": "tsc -b && node node_modules/vite/bin/vite.js build",
    "postbuild": "node scripts/generate-archive-pages.mjs && node scripts/generate-works-pages.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "serve:dist": "node scripts/serve-dist.mjs"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "@vitejs/plugin-react-swc": "^3.7.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.3",
    "vite": "^5.4.21"
  },
  "devDependencies": {
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "latest",
    "esbuild": "^0.21.5",
    "postcss": "latest",
    "sharp": "^0.35.1",
    "tailwindcss": "^3.4.17"
  }
}
